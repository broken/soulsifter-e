{
  "name": "soulsifter",
  "version": "1.11.0",
  "description": "back end for Soulsifter app",
  "main": "index.js",
  "private": true,
  "scripts": {
    "be:build": "npm i",
    "be:compile": "npm run be:build && npm run be:rebuild",
    "be:generatemodel": "ruby generate_model.rb",
    "be:rebuild": "HOME=~/.electron-gyp npx node-gyp rebuild --target=42.3.3 --dist-url=https://electronjs.org/headers",
    "be:test": "npm run be:build && node test.js"
  },
  "author": "Robert Neale",
  "license": "Apache-2.0",
  "gypfile": false,
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.2.1"
  },
  "devDependencies": {
    "node-gyp": "^10.2.0"
  }
}
